# Frontend (Vite) environment — copy to .env. Only VITE_-prefixed vars reach the
# browser. Supabase is removed; the SPA talks only to the Python backend.

# Base URL of the Python (FastAPI) backend.
VITE_API_BASE_URL="http://localhost:8000"

# Public OAuth client identifiers (NOT secrets — the matching secrets live in the
# backend .env). Leave blank to disable a provider; its button then degrades to a
# "not configured yet" message instead of starting a broken flow.
VITE_GOOGLE_CLIENT_ID=""
VITE_APPLE_CLIENT_ID=""
