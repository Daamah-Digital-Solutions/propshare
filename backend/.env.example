# Copy to .env and fill in. NEVER commit the real .env (see .gitignore).

# Async SQLAlchemy URL to the self-hosted VPS Postgres (privileged role).
# Example for local docker-compose Postgres:
DATABASE_URL=postgresql+asyncpg://capimax:capimax@localhost:5432/capimax

# Sync URL Alembic uses for migrations (psycopg). Defaults are derived from
# DATABASE_URL if left blank; set explicitly for clarity.
ALEMBIC_DATABASE_URL=postgresql+psycopg://capimax:capimax@localhost:5432/capimax

REDIS_URL=redis://localhost:6379/0

ENVIRONMENT=local            # local | staging | production
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:5173   # used to build email verify/reset links
LOG_LEVEL=INFO

# --- Auth / JWT (Phase 1) ---
# MUST be a long random string in staging/production (>= 32 bytes). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-insecure-change-me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
COOKIE_SECURE=false          # true in staging/production (HTTPS)
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=

# --- Email (Phase 1: verification + password reset only) ---
EMAIL_PROVIDER=console       # console | resend | smtp
EMAIL_FROM=CapiMax <no-reply@capimax.local>
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- OAuth (Phase 1: Google + Apple). Leave blank to disable a provider. ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=             # Services ID
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=           # contents of the .p8 (use a multi-line / escaped value)

# --- KYC / Sumsub (Phase 2). Empty app token/secret => KYC disabled (honest 503). ---
SUMSUB_BASE_URL=https://api.sumsub.com
SUMSUB_APP_TOKEN=            # Sumsub App Token (REST API)
SUMSUB_SECRET_KEY=          # Sumsub Secret Key (signs outbound API requests)
SUMSUB_WEBHOOK_SECRET=      # Sumsub webhook secret (verifies X-Payload-Digest)
SUMSUB_LEVEL_NAME=basic-kyc-level

# --- Payments / deposits (Phase 4). Empty creds => provider disabled (honest 503). ---
WALLET_CURRENCY=USD
# Stripe (cards / Apple Pay / Google Pay)
STRIPE_SECRET_KEY=            # sk_test_... / sk_live_...
STRIPE_WEBHOOK_SECRET=        # whsec_... (from `stripe listen` locally, or the dashboard)
STRIPE_PUBLISHABLE_KEY=       # pk_... (optional; hosted Checkout doesn't need it in the SPA)
# NOWPayments (crypto) — IPN signed HMAC-SHA512 in the x-nowpayments-sig header
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true      # api-sandbox.nowpayments.io while testing
